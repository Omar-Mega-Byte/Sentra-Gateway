{
  "info": {
    "_postman_id": "d451e880-e729-4cf8-8ea5-b06e35e97373",
    "name": "Sentra Order Service",
    "description": "Direct local verification of the internal order-service contract. These X-Sentra-* headers simulate values created by Sentra Gateway and must never be accepted from public traffic.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Readiness is UP",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/actuator/health/readiness"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('readiness is UP', () => {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('UP');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "OpenAPI contains all operations",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/v3/api-docs"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('all four operations are documented', () => {",
              "  pm.response.to.have.status(200);",
              "  const api = pm.response.json();",
              "  pm.expect(api.paths['/internal/v1/orders'].get).to.exist;",
              "  pm.expect(api.paths['/internal/v1/orders'].post).to.exist;",
              "  pm.expect(api.paths['/internal/v1/orders/{id}'].get).to.exist;",
              "  pm.expect(api.paths['/internal/v1/admin/orders'].get).to.exist;",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "List owned orders",
      "request": {
        "method": "GET",
        "header": [
          {"key": "X-Sentra-Request-Id", "value": "postman-list-001"},
          {"key": "X-Sentra-Subject", "value": "{{subject}}"},
          {"key": "X-Sentra-Actor-Type", "value": "USER"},
          {"key": "X-Sentra-Tenant-Id", "value": "{{tenantId}}"},
          {"key": "X-Sentra-Scopes", "value": "orders:read"},
          {"key": "X-Sentra-Route-Id", "value": "orders-list"}
        ],
        "url": "{{baseUrl}}/internal/v1/orders?page=0&size=20"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('only the trusted owner partition is returned', () => {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.totalElements).to.eql(2);",
              "  pm.expect(body.items).to.have.length(2);",
              "  body.items.forEach(order => {",
              "    pm.expect(order).not.to.have.property('ownerSubject');",
              "    pm.expect(order).not.to.have.property('tenantId');",
              "  });",
              "  pm.expect(pm.response.headers.get('Cache-Control')).to.include('no-store');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get owned order",
      "request": {
        "method": "GET",
        "header": [
          {"key": "X-Sentra-Request-Id", "value": "postman-get-001"},
          {"key": "X-Sentra-Subject", "value": "{{subject}}"},
          {"key": "X-Sentra-Actor-Type", "value": "USER"},
          {"key": "X-Sentra-Tenant-Id", "value": "{{tenantId}}"},
          {"key": "X-Sentra-Scopes", "value": "orders:read"},
          {"key": "X-Sentra-Route-Id", "value": "orders-get"}
        ],
        "url": "{{baseUrl}}/internal/v1/orders/{{ownedOrderId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('owned order is returned safely', () => {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.id).to.eql(pm.environment.get('ownedOrderId'));",
              "  pm.expect(body).not.to.have.property('ownerSubject');",
              "  pm.expect(body).not.to.have.property('tenantId');",
              "});"
            ]
          }
        }
      ]
    },
    {
