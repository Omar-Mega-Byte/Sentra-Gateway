    {
      "name": "Create keyed order",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "X-Sentra-Request-Id", "value": "postman-create-001"},
          {"key": "X-Sentra-Subject", "value": "{{subject}}"},
          {"key": "X-Sentra-Actor-Type", "value": "USER"},
          {"key": "X-Sentra-Tenant-Id", "value": "{{tenantId}}"},
          {"key": "X-Sentra-Scopes", "value": "orders:write"},
          {"key": "X-Sentra-Route-Id", "value": "orders-create"},
          {"key": "Idempotency-Key", "value": "{{idempotencyKey}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"items\":[{\"sku\":\"BOOK-JAVA-25\",\"quantity\":1}]}",
          "options": {"raw": {"language": "json"}}
        },
        "url": "{{baseUrl}}/internal/v1/orders"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('create returns a server-controlled order', () => {",
              "  pm.response.to.have.status(201);",
              "  const body = pm.response.json();",
              "  pm.expect(body.status).to.eql('CREATED');",
              "  pm.expect(body).not.to.have.property('ownerSubject');",
              "  pm.expect(pm.response.headers.get('Location')).to.include(body.id);",
              "  pm.expect(pm.response.headers.get('Idempotency-Replayed')).to.eql('false');",
              "  pm.environment.set('createdOrderBody', pm.response.text());",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Replay keyed order",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "X-Sentra-Request-Id", "value": "postman-create-replay-001"},
          {"key": "X-Sentra-Subject", "value": "{{subject}}"},
          {"key": "X-Sentra-Actor-Type", "value": "USER"},
          {"key": "X-Sentra-Tenant-Id", "value": "{{tenantId}}"},
          {"key": "X-Sentra-Scopes", "value": "orders:write"},
          {"key": "X-Sentra-Route-Id", "value": "orders-create"},
          {"key": "Idempotency-Key", "value": "{{idempotencyKey}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"items\":[{\"quantity\":1,\"sku\":\"BOOK-JAVA-25\"}]}",
          "options": {"raw": {"language": "json"}}
        },
        "url": "{{baseUrl}}/internal/v1/orders"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('same key and payload replays the original result', () => {",
              "  pm.response.to.have.status(201);",
              "  pm.expect(pm.response.headers.get('Idempotency-Replayed')).to.eql('true');",
              "  pm.expect(pm.response.text()).to.eql(pm.environment.get('createdOrderBody'));",
              "  pm.expect(pm.response.headers.get('X-Request-Id')).to.eql('postman-create-replay-001');",
              "});"
            ]
          }
        }
      ]
    },
