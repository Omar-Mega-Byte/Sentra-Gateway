{
  "info": {
    "_postman_id": "c2ccb393-00b1-4e5f-81da-39d0b2b19b16",
    "name": "Sentra User Service",
    "description": "Direct internal-contract verification for the user service. Trusted headers simulate values produced by gateway-service; no bearer token is accepted by user-service.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Management",
      "item": [
        {
          "name": "Readiness",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/actuator/health/readiness"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('readiness is UP', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().status).to.eql('UP');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "OpenAPI",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v3/api-docs"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('OpenAPI contains all profile operations', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const api = pm.response.json();",
                  "  pm.expect(api.paths['/internal/v1/users/{id}/public'].get).to.exist;",
                  "  pm.expect(api.paths['/internal/v1/users/me'].get).to.exist;",
                  "  pm.expect(api.paths['/internal/v1/users/me'].patch).to.exist;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Public Profile",
      "item": [
        {
          "name": "Get public profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Sentra-Request-Id",
                "value": "{{$guid}}"
              },
              {
                "key": "X-Sentra-Route-Id",
                "value": "user-public-profile"
              }
            ],
            "url": "{{baseUrl}}/internal/v1/users/{{activeProfileId}}/public"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('public response is strictly redacted', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(Object.keys(body).sort()).to.eql(['avatarUrl', 'bio', 'displayName', 'id']);",
                  "  pm.expect(body).to.not.have.property('email');",
                  "  pm.expect(body).to.not.have.property('subject');",
                  "  pm.expect(pm.response.headers.get('X-Request-Id')).to.exist;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Reject missing provenance",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/internal/v1/users/{{activeProfileId}}/public"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('missing trusted context is rejected', function () {",
                  "  pm.response.to.have.status(401);",
                  "  pm.expect(pm.response.json().code).to.eql('USR_TRUSTED_CONTEXT_REQUIRED');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Current Profile",
      "item": [
        {
          "name": "Read current profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Sentra-Request-Id",
                "value": "{{$guid}}"
              },
              {
                "key": "X-Sentra-Subject",
                "value": "{{subject}}"
              },
              {
                "key": "X-Sentra-Actor-Type",
                "value": "USER"
              },
              {
                "key": "X-Sentra-Scopes",
                "value": "profile:read"
              },
              {
                "key": "X-Sentra-Route-Id",
                "value": "user-profile-read"
              }
            ],
            "url": "{{baseUrl}}/internal/v1/users/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('trusted subject resolves the private profile', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.email).to.exist;",
                  "  pm.expect(body).to.not.have.property('subject');",
                  "  pm.expect(body).to.not.have.property('status');",
                  "  pm.environment.set('currentVersion', body.version);",
                  "  pm.environment.set('originalDisplayName', body.displayName);",
                  "  pm.environment.set('originalBio', body.bio || '');",
                  "  pm.environment.set('originalAvatarUrl', body.avatarUrl || '');",
                  "  pm.environment.set('originalEmail', body.email);",
                  "  pm.environment.set('originalLocale', body.locale);",
                  "  pm.environment.set('originalTimezone', body.timezone);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Reject API client actor",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Sentra-Request-Id",
                "value": "{{$guid}}"
              },
              {
                "key": "X-Sentra-Subject",
                "value": "{{subject}}"
              },
              {
                "key": "X-Sentra-Actor-Type",
                "value": "API_CLIENT"
              },
              {
                "key": "X-Sentra-Scopes",
                "value": "profile:read"
              },
              {
                "key": "X-Sentra-Route-Id",
                "value": "user-profile-read"
              }
            ],
            "url": "{{baseUrl}}/internal/v1/users/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('non-user actor is rejected', function () {",
                  "  pm.response.to.have.status(403);",
                  "  pm.expect(pm.response.json().code).to.eql('USR_ACTOR_NOT_ALLOWED');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Reject missing scope",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Sentra-Request-Id",
                "value": "{{$guid}}"
              },
              {
                "key": "X-Sentra-Subject",
                "value": "{{subject}}"
              },
              {
                "key": "X-Sentra-Actor-Type",
                "value": "USER"
              },
              {
                "key": "X-Sentra-Scopes",
                "value": "orders:read"
              },
              {
                "key": "X-Sentra-Route-Id",
                "value": "user-profile-read"
              }
            ],
            "url": "{{baseUrl}}/internal/v1/users/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('missing profile scope is rejected', function () {",
                  "  pm.response.to.have.status(403);",
                  "  pm.expect(pm.response.json().code).to.eql('USR_SCOPE_REQUIRED');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update current profile",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Sentra-Request-Id",
                "value": "{{$guid}}"
              },
              {
                "key": "X-Sentra-Subject",
                "value": "{{subject}}"
              },
              {
                "key": "X-Sentra-Actor-Type",
                "value": "USER"
              },
              {
                "key": "X-Sentra-Scopes",
                "value": "profile:write"
              },
              {
                "key": "X-Sentra-Route-Id",
                "value": "user-profile-update"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"Postman Verified User\",\n  \"version\": {{currentVersion}}\n}"
            },
            "url": "{{baseUrl}}/internal/v1/users/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('profile update increments exactly once', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.version).to.eql(Number(pm.environment.get('currentVersion')) + 1);",
                  "  pm.environment.set('updatedVersion', body.version);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Reject stale version",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Sentra-Request-Id",
                "value": "{{$guid}}"
              },
              {
                "key": "X-Sentra-Subject",
                "value": "{{subject}}"
              },
              {
                "key": "X-Sentra-Actor-Type",
                "value": "USER"
              },
              {
                "key": "X-Sentra-Scopes",
                "value": "profile:write"
              },
              {
                "key": "X-Sentra-Route-Id",
                "value": "user-profile-update"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"Stale Update\",\n  \"version\": {{currentVersion}}\n}"
            },
            "url": "{{baseUrl}}/internal/v1/users/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('stale version returns conflict', function () {",
                  "  pm.response.to.have.status(409);",
                  "  pm.expect(pm.response.json().code).to.eql('USR_VERSION_CONFLICT');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Reject unknown field",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Sentra-Request-Id",
                "value": "{{$guid}}"
              },
              {
                "key": "X-Sentra-Subject",
                "value": "{{subject}}"
              },
              {
                "key": "X-Sentra-Actor-Type",
                "value": "USER"
              },
              {
                "key": "X-Sentra-Scopes",
                "value": "profile:write"
              },
              {
                "key": "X-Sentra-Route-Id",
                "value": "user-profile-update"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"forged\",\n  \"version\": {{updatedVersion}}\n}"
            },
            "url": "{{baseUrl}}/internal/v1/users/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('immutable and unknown fields are rejected', function () {",
                  "  pm.response.to.have.status(400);",
                  "  pm.expect(pm.response.json().code).to.eql('USR_REQUEST_INVALID');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Reject oversized body",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.variables.set('largeBio', 'x'.repeat(17000));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('oversized body is rejected', function () {",
                  "  pm.response.to.have.status(413);",
                  "  pm.expect(pm.response.json().code).to.eql('USR_BODY_TOO_LARGE');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Sentra-Request-Id",
                "value": "{{$guid}}"
              },
              {
                "key": "X-Sentra-Subject",
                "value": "{{subject}}"
              },
              {
                "key": "X-Sentra-Actor-Type",
                "value": "USER"
              },
              {
                "key": "X-Sentra-Scopes",
                "value": "profile:write"
              },
              {
                "key": "X-Sentra-Route-Id",
                "value": "user-profile-update"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bio\": \"{{largeBio}}\",\n  \"version\": {{updatedVersion}}\n}"
            },
            "url": "{{baseUrl}}/internal/v1/users/me"
          }
        },
        {
          "name": "Restore profile values",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Sentra-Request-Id",
                "value": "{{$guid}}"
              },
              {
                "key": "X-Sentra-Subject",
                "value": "{{subject}}"
              },
              {
                "key": "X-Sentra-Actor-Type",
                "value": "USER"
              },
              {
                "key": "X-Sentra-Scopes",
                "value": "profile:write"
              },
              {
                "key": "X-Sentra-Route-Id",
                "value": "user-profile-update"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"{{originalDisplayName}}\",\n  \"bio\": \"{{originalBio}}\",\n  \"avatarUrl\": \"{{originalAvatarUrl}}\",\n  \"email\": \"{{originalEmail}}\",\n  \"locale\": \"{{originalLocale}}\",\n  \"timezone\": \"{{originalTimezone}}\",\n  \"version\": {{updatedVersion}}\n}"
            },
            "url": "{{baseUrl}}/internal/v1/users/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('original values are restored', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().displayName).to.eql(pm.environment.get('originalDisplayName'));",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
