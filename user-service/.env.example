SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8081
SENTRA_ENVIRONMENT=local
SENTRA_INSTANCE_ID=user-service-local
SERVICE_NAME=user-service
SHUTDOWN_TIMEOUT=20s
PROFILE_REPOSITORY_MODE=memory
PROFILE_SEED_ENABLED=true
PROFILE_EMAIL_UNIQUE=true
GATEWAY_CONTEXT_REQUIRED=true
GATEWAY_ALLOWED_ROUTE_IDS=user-public-profile,user-profile-read,user-profile-update
GATEWAY_ALLOWED_PEERS=gateway-service
TRUSTED_HEADER_MAX_LENGTH=255
REQUEST_ID_MAX_LENGTH=128
MAX_REQUEST_BODY_BYTES=16384
MAX_DISPLAY_NAME_LENGTH=100
MAX_BIO_LENGTH=500
MAX_AVATAR_URL_LENGTH=2048
MAX_EMAIL_LENGTH=254
MAX_LOCALE_LENGTH=35
MAX_TIMEZONE_LENGTH=64
MAX_ERROR_DETAILS=20
PUBLIC_PROFILE_ENABLED=true
PUBLIC_PROFILE_CACHE_CONTROL=public, max-age=60
PUBLIC_PROFILE_NOT_FOUND_CACHE_CONTROL=no-store
MANAGEMENT_PORT=8081
MANAGEMENT_ALLOWED_CIDRS=
OPENAPI_ENABLED=true
SWAGGER_UI_ENABLED=true
METRICS_ENABLED=true
LOG_LEVEL_ROOT=INFO
LOG_INCLUDE_PROFILE_IDS=false
SENTRA_SERVICES_NETWORK=sentra-gateway_services
