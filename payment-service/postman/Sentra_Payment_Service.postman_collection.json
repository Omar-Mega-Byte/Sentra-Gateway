    {
      "name": "Missing signature evidence is rejected",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('deniedRef', 'acme-order-denied-' + Date.now());"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('missing signature evidence returns 403', function () {",
              "  pm.response.to.have.status(403);",
              "  pm.expect(pm.response.json().code).to.eql('PAY_SIGNATURE_CONTEXT_REQUIRED');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Idempotency-Key", "value": "missing-signature-{{$timestamp}}"},
          {"key": "X-Sentra-Request-Id", "value": "{{requestId}}"},
          {"key": "X-Sentra-Actor-Type", "value": "API_CLIENT"},
          {"key": "X-Sentra-Client-Id", "value": "{{clientId}}"},
          {"key": "X-Sentra-Key-Id", "value": "{{keyId}}"},
          {"key": "X-Sentra-Scopes", "value": "payments:write"},
          {"key": "X-Sentra-Route-Id", "value": "partner-payment-create"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"merchantReference\":\"{{deniedRef}}\",\"amount\":\"12.00\",\"currency\":\"USD\"}"
        },
        "url": "{{baseUrl}}/internal/v1/payments"
      }
    },
    {
      "name": "Create payment",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const runId = Date.now() + '-' + Math.floor(Math.random() * 100000);",
              "pm.collectionVariables.set('paymentRef', 'acme-order-postman-' + runId);",
              "pm.collectionVariables.set('paymentKey', 'postman-payment-key-' + runId);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('payment create succeeds', function () {",
              "  pm.response.to.have.status(201);",
              "  pm.expect(pm.response.headers.get('Idempotency-Replayed')).to.eql('false');",
              "  pm.expect(pm.response.json().status).to.eql('AUTHORIZED');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Idempotency-Key", "value": "{{paymentKey}}"},
          {"key": "X-Sentra-Request-Id", "value": "{{requestId}}"},
          {"key": "X-Sentra-Actor-Type", "value": "API_CLIENT"},
          {"key": "X-Sentra-Client-Id", "value": "{{clientId}}"},
          {"key": "X-Sentra-Key-Id", "value": "{{keyId}}"},
          {"key": "X-Sentra-Scopes", "value": "payments:write"},
          {"key": "X-Sentra-Route-Id", "value": "partner-payment-create"},
          {"key": "X-Sentra-Signature-Verified", "value": "true"},
          {"key": "X-Sentra-Signature-Key-Id", "value": "{{signatureKeyId}}"},
          {"key": "X-Sentra-Nonce-Status", "value": "accepted"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"merchantReference\":\"{{paymentRef}}\",\"amount\":\"125.50\",\"currency\":\"USD\",\"description\":\"Postman payment-service smoke\"}"
        },
        "url": "{{baseUrl}}/internal/v1/payments"
      }
    },
