{
  "info": {
    "_postman_id": "5871d53a-a2fc-42dd-b177-5837a0a74b9e",
    "name": "Sentra Payment Service",
    "description": "Direct local collection for payment-service internal APIs. These requests simulate trusted headers created by Sentra Gateway; partner API-key, HMAC, and replay validation must still be verified through gateway-service.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Readiness is UP",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('readiness is UP', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('UP');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/actuator/health/readiness"
      }
    },
    {
      "name": "OpenAPI contains payment operations",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('OpenAPI includes all internal payment paths', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.paths['/internal/v1/payments/{id}'].get).to.be.an('object');",
              "  pm.expect(body.paths['/internal/v1/payments'].post).to.be.an('object');",
              "  pm.expect(body.paths['/internal/v1/refunds'].post).to.be.an('object');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/v3/api-docs"
      }
    },
    {
      "name": "Read owned payment",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('owned payment is returned and redacted', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.id).to.eql(pm.environment.get('ownedPaymentId'));",
              "  pm.expect(body.clientId).to.be.undefined;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {"key": "X-Sentra-Request-Id", "value": "{{requestId}}"},
          {"key": "X-Sentra-Actor-Type", "value": "API_CLIENT"},
          {"key": "X-Sentra-Client-Id", "value": "{{clientId}}"},
          {"key": "X-Sentra-Key-Id", "value": "{{keyId}}"},
          {"key": "X-Sentra-Scopes", "value": "payments:read"},
          {"key": "X-Sentra-Route-Id", "value": "partner-payment-read"}
        ],
        "url": "{{baseUrl}}/internal/v1/payments/{{ownedPaymentId}}"
      }
    },
    {
      "name": "Foreign payment returns safe 404",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('foreign payment is hidden', function () {",
              "  pm.response.to.have.status(404);",
              "  pm.expect(pm.response.json().code).to.eql('PAY_PAYMENT_NOT_FOUND');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {"key": "X-Sentra-Request-Id", "value": "{{requestId}}"},
          {"key": "X-Sentra-Actor-Type", "value": "API_CLIENT"},
          {"key": "X-Sentra-Client-Id", "value": "{{clientId}}"},
